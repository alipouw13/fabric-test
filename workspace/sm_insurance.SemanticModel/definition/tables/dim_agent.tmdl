table dim_agent

	column agent_id
		dataType: string
		summarizeBy: none
		sourceColumn: agent_id

	column agent_name
		dataType: string
		summarizeBy: none
		sourceColumn: agent_name

	column region
		dataType: string
		summarizeBy: none
		sourceColumn: region

	column channel
		dataType: string
		summarizeBy: none
		sourceColumn: channel

	column hire_date
		dataType: dateTime
		formatString: Long Date
		summarizeBy: none
		sourceColumn: hire_date

	partition dim_agent = entity
		mode: directLake
		source
			entityName: dim_agent
			schemaName: gold
			expressionSource: DL_Insurance

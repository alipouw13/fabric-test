table dim_date
	dataCategory: Time

	column date
		dataType: dateTime
		formatString: Long Date
		summarizeBy: none
		sourceColumn: date

	column date_key
		dataType: int64
		isHidden
		summarizeBy: none
		sourceColumn: date_key

	column year
		dataType: int64
		summarizeBy: none
		sourceColumn: year

	column quarter
		dataType: int64
		summarizeBy: none
		sourceColumn: quarter

	column month
		dataType: int64
		summarizeBy: none
		sourceColumn: month

	column month_name
		dataType: string
		summarizeBy: none
		sourceColumn: month_name

	column day_of_month
		dataType: int64
		summarizeBy: none
		sourceColumn: day_of_month

	column year_month
		dataType: string
		summarizeBy: none
		sourceColumn: year_month

	hierarchy 'Calendar Hierarchy'

		level Year
			column: year

		level Quarter
			column: quarter

		level Month
			column: month_name

	partition dim_date = entity
		mode: directLake
		source
			entityName: dim_date
			schemaName: gold
			expressionSource: DL_Insurance
